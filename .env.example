# Mintcn env vars
# Copy this file to `.env.local` and fill in real values.
# .env.local is git-ignored; don't put secrets in .env.example.

# --- Client-side (exposed to browser via Vite) ---
# GitHub OAuth App Client ID. Safe to expose. Get one at:
#   https://github.com/settings/developers → OAuth Apps
VITE_GITHUB_CLIENT_ID=

# --- Server-side (never exposed to browser) ---
# GitHub OAuth App Client Secret. NEVER prefix with VITE_.
# Used only by the /api/auth/callback function to exchange the OAuth code
# for an access token.
GITHUB_CLIENT_SECRET=
